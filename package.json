{
  "name": "hyperlocal-delivery-app",
  "version": "1.0.0",
  "description": "Hyper-local delivery dispatcher - Fullstack application with Node.js backend and React frontend",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "seed": "cd backend && node seeder.js",
    "build": "cd frontend && npm run build"
  },
  "keywords": [
    "delivery",
    "dispatcher",
    "hyperlocal",
    "nodejs",
    "react",
    "mongodb",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
